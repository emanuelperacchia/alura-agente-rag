# ============================================================
# Santos Pegasus Soluciones - Variables de Entorno
# ============================================================
# Copiá este archivo como .env y completá las configuraciones.

# ─── Proveedor de LLM ───────────────────────────────────────
# Valores posibles: "cohere" | "openrouter"
LLM_PROVIDER=cohere

# ─── Cohere (si LLM_PROVIDER=cohere) ───────────────────────
# Obtené tu API key en: https://dashboard.cohere.com/api-keys
COHERE_API_KEY=tu_api_key_de_cohere

# ─── OpenRouter (si LLM_PROVIDER=openrouter) ───────────────
# Obtené tu API key en: https://openrouter.ai/settings/keys
# OPENROUTER_API_KEY=tu_api_key_de_openrouter
# OPENROUTER_MODEL=google/gemma-3n-e2b-it:free

# ─── Rutas (opcional - valores por defecto) ─────────────────
# Directorio con los PDFs de documentación
# PDF_DIR=../Docs/Santos Pegasus Soluciones/
# CHROMA_PATH=data/chroma_db

.venv/

# ─── IDE y OS ──────────────────────────────────────────────
.idea/
.vscode/
.DS_Store
Thumbs.db

# ─── Git ───────────────────────────────────────────────────
.git/
.gitignore

# ─── Documentación (no necesaria en runtime) ───────────────
*.md
scripts/
